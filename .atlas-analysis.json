{
  "projectType": "saas",
  "projectName": "LLM Council",
  "projectDescription": "A local web app that routes your questions to multiple LLMs simultaneously, has them anonymously peer-review each other's answers, and synthesizes a final response via a designated Chairman model.",
  "theme": "luma",
  "primaryColor": "#7c7c7c",
